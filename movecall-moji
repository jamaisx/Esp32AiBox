esphome:
  name: chatbot

rtttl:
  speaker: moji_speaker

button:
  - platform: restart
    name: "Riavvia Dispositivo"
    icon: "mdi:restart"
    entity_category: diagnostic
  - platform: template
    name: "Avvia Assistente Vocale"
    id: avvia_vocale
    icon: "mdi:microphone"
    on_press:
      - voice_assistant.start:  
  - platform: template
    name: "Test Suono Locale"
    on_press:
      - rtttl.play: "short_beep:d=4,o=5,b=100:16e6"    
      
ota:
  platform: esphome
  
logger:
  level: DEBUG

psram:
  mode: octal
  
esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf
    sdkconfig_options:
      CONFIG_SPIRAM: y
      CONFIG_SPIRAM_MODE_OCT: y
      CONFIG_SPIRAM_SPEED_80M: y
      CONFIG_SPIRAM_USE_MALLOC: y
      CONFIG_SPIRAM_BOOT_INIT: y 
      
audio_dac:
  - platform: es8311
    id: moji_codec
    address: 0x18
    i2c_id: bus_a

i2c:
  - id: bus_a
    sda: GPIO5
    scl: GPIO4
    scan: true

i2s_audio:
  - id: i2s_bus
    i2s_lrclk_pin: GPIO12
    i2s_bclk_pin: GPIO14
    i2s_mclk_pin: GPIO6

speaker:
  - platform: i2s_audio
    id: moji_speaker
    i2s_audio_id: i2s_bus
    dac_type: external
    i2s_dout_pin: GPIO11
    audio_dac: moji_codec

microphone:
  - platform: i2s_audio
    id: moji_mic
    i2s_audio_id: i2s_bus
    i2s_din_pin: GPIO13 
    adc_type: external
    pdm: false 
    channel: left
#    on_data:
#      - logger.log: "Dati microfono ricevuti"
    
binary_sensor:
  - platform: gpio
    pin:
      number: GPIO0
      inverted: true
      mode: INPUT_PULLUP
    name: "Tasto Risveglio"
    on_press:
      - voice_assistant.start:

light:
  - platform: esp32_rmt_led_strip
    id: led_stato
    pin: GPIO21
    num_leds: 1
    rgb_order: GRB  
    chipset: WS2812
    name: "Status LED"
    effects:
    - pulse:
        name: "Pulse"
        transition_length: 1000ms
        update_interval: 1000ms     

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

api:
  encryption:
    key: !secret api_key 
  on_client_connected:
    then:
      - logger.log: "Avvio riconoscimento"
      - voice_assistant.start_continuous

media_player:
  - platform: speaker
    name: "Moji Media Player"
    id: moji_media_player
    announcement_pipeline:
      speaker: moji_speaker
    on_play:
      - switch.turn_on: amp_pin
    on_pause:
      - switch.turn_off: amp_pin
    on_idle:
      - switch.turn_off: amp_pin
      - light.turn_off: led_stato
      #- voice_assistant.start_continuous
    on_announcement: 
      - switch.turn_on: amp_pin
      - light.turn_on: 
          id: led_stato
          red: 1.0
          green: 0.0
          blue: 0.5 # Viola
          brightness: 50%

micro_wake_word:
  id: micro_ww
  models:
    - model: okay_nabu  
  on_wake_word_detected:
    - logger.log: "Dati wakeword ricevuti"
                
voice_assistant:
  id: va
  microphone: moji_mic
  speaker: moji_speaker
  use_wake_word: false
  noise_suppression_level: 2
#  micro_wake_word: micro_ww
  auto_gain: 31DBFS
  volume_multiplier: 4.0
  # amplification: 3.0
  conversation_timeout: 1.5s

  on_stt_end:
    - logger.log:
        format: "Hai detto: %s"
        args: [ 'x.c_str()' ]
    - light.turn_off: led_stato
  on_listening:
    - light.turn_on:
        id: led_stato
        red: 0%
        green: 100%
        blue: 0%
        effect: "Pulse"    
  on_error:
    - light.turn_on:
        id: led_stato
        red: 100%
        green: 0%
        blue: 0%
    - delay: 1s
    - light.turn_off: led_stato
        
switch:
  - platform: gpio
    pin: GPIO9
    name: "Amplificatore Audio"
    id: amp_pin
    restore_mode: ALWAYS_OFF

sensor:
  - platform: adc
    pin: GPIO1 # Corrisponde ad A0 sul modulo XIAO ESP32-S3
    name: "Moji Battery Voltage"
    id: moji_vbatt
    update_interval: 60s
    attenuation: 12db # Necessario per leggere fino a 3.1V - 4.2V
    filters:
      - multiply: 2.0 
      - exponential_moving_average:
          alpha: 0.1
          send_every: 1
    entity_category: diagnostic

  - platform: template
    name: "Moji Battery Percentage"
    unit_of_measurement: "%"
    device_class: battery
    lambda: |-
      float voltage = id(moji_vbatt).state;
      if (voltage >= 4.2) return 100.0;
      if (voltage <= 3.3) return 0.0;
      return (voltage - 3.3) / (4.2 - 3.3) * 100.0;
  - platform: sound_level  # Nota: 'sound_level', non 'sound_level_meter'
    id: mic_test
    microphone: moji_mic
    passive: true 
    
    # Necessario se il microfono  gia usato da voice_assistant
    

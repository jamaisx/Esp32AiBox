esphome:
  name: movecall-moji

logger:
  level: DEBUG
  
esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf
    sdkconfig_options:
      CONFIG_SPIRAM: y
      CONFIG_SPIRAM_MODE_OCT: y
      CONFIG_SPIRAM_SPEED_80M: y
      CONFIG_SPIRAM_USE_MALLOC: y
      CONFIG_SPIRAM_BOOT_INIT: y 
      
audio_dac:
  - platform: es8311
    id: moji_codec
    address: 0x18
    i2c_id: bus_a

i2c:
  - id: bus_a
    sda: GPIO5
    scl: GPIO4
    scan: true

i2s_audio:
  - id: i2s_bus
    i2s_lrclk_pin: GPIO12
    i2s_bclk_pin: GPIO14
    i2s_mclk_pin: GPIO6

microphone:
  - platform: i2s_audio
    id: moji_mic
    i2s_audio_id: i2s_bus
    i2s_din_pin: GPIO13
    adc_type: external
    pdm: false 

binary_sensor:
  - platform: gpio
    pin:
      number: GPIO0
      inverted: true
      mode: INPUT_PULLUP
    name: "Tasto Risveglio"
    on_press:
      - voice_assistant.start:

light:
  - platform: esp32_rmt_led_strip
    id: led_stato
    pin: GPIO21
    num_leds: 1
    rgb_order: GRB  
    chipset: WS2812
    name: "Status LED"
    effects:
    - pulse:
        name: "Pulse"
        transition_length: 1000ms
        update_interval: 1000ms

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  
api:
  encryption:
    key: !secret api_key 

speaker:
  - platform: i2s_audio
    id: moji_speaker
    i2s_audio_id: i2s_bus
    dac_type: external
    i2s_dout_pin: GPIO11

media_player:
  - platform: speaker
    name: "Moji Media Player"
    id: moji_media_player
    announcement_pipeline:
      speaker: moji_speaker
    on_play:
      - switch.turn_on: amp_pin
    on_pause:
      - switch.turn_off: amp_pin
    on_idle:
      - switch.turn_off: amp_pin
      - light.turn_off: led_stato
    on_announcement: 
      - switch.turn_on: amp_pin
      - light.turn_on: led_stato
        
voice_assistant:
  id: va
  microphone: moji_mic
  speaker: moji_speaker
  use_wake_word: true

switch:
  - platform: gpio
    pin: GPIO9
    name: "Amplificatore Audio"
    id: amp_pin
    restore_mode: ALWAYS_OFF
